<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="dog_bot">
    <self_collide>false</self_collide>

    <link name="chassis">
      <pose>0 0 0.3 0 0 0</pose>
      <inertial>
        <mass>20.0</mass>
        <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz></inertia>
      </inertial>
      <visual name="v">
        <geometry><box><size>1.0 0.5 0.2</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>1.0 0.5 0.2</size></box></geometry>
      </collision>
    </link>

    <!-- FRONT LEFT ASSEMBLY (Steer + Roll) -->
    <link name="fl_steer_hinge">
      <pose>0.4 0.35 0.3 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia></inertial>
    </link>
    <joint name="fl_steer_j" type="revolute">
      <parent>chassis</parent><child>fl_steer_hinge</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-0.6</lower><upper>0.6</upper><effort>1000</effort></limit></axis>
    </joint>
    <link name="fl_wheel">
      <pose>0.4 0.35 0.3 -1.5708 0 0</pose>
      <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry></collision>
    </link>
    <joint name="fl_wheel_j" type="revolute">
      <parent>fl_steer_hinge</parent><child>fl_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><effort>100000</effort></limit></axis>
    </joint>

    <!-- FRONT RIGHT ASSEMBLY (Steer + Roll) -->
    <link name="fr_steer_hinge">
      <pose>0.4 -0.35 0.3 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia></inertial>
    </link>
    <joint name="fr_steer_j" type="revolute">
      <parent>chassis</parent><child>fr_steer_hinge</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-0.6</lower><upper>0.6</upper><effort>1000</effort></limit></axis>
    </joint>
    <link name="fr_wheel">
      <pose>0.4 -0.35 0.3 -1.5708 0 0</pose>
      <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry></collision>
    </link>
    <joint name="fr_wheel_j" type="revolute">
      <parent>fr_steer_hinge</parent><child>fr_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><effort>100000</effort></limit></axis>
    </joint>

    <!-- REAR LEFT (Drive Only) -->
    <link name="rl_wheel">
      <pose>-0.4 0.35 0.3 -1.5708 0 0</pose>
      <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry></collision>
    </link>
    <joint name="rl_drive_j" type="revolute">
      <parent>chassis</parent><child>rl_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper><effort>100000</effort></limit></axis>
    </joint>

    <!-- REAR RIGHT (Drive Only) -->
    <link name="rr_wheel">
      <pose>-0.4 -0.35 0.3 -1.5708 0 0</pose>
      <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry></collision>
    </link>
    <joint name="rr_drive_j" type="revolute">
      <parent>chassis</parent><child>rr_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper><effort>100000</effort></limit></axis>
    </joint>
<!-- PLUGINS -->
    <!-- 1. Joint State Publisher -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>

    <!-- 2. Drive Controllers (Rear Wheels) -->
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>rl_drive_j</joint_name>
      <sub_topic>joint/rl_drive_j/cmd_vel</sub_topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>rr_drive_j</joint_name>
      <sub_topic>joint/rr_drive_j/cmd_vel</sub_topic>
    </plugin>

    <!-- 3. Steering Controllers (Front Hinge Pivot) -->
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>fl_steer_j</joint_name>
      <sub_topic>joint/fl_steer_j/cmd_vel</sub_topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>fr_steer_j</joint_name>
      <sub_topic>joint/fr_steer_j/cmd_vel</sub_topic>
    </plugin>

  </model>
</sdf>
